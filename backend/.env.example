# MongoDB Atlas Connection String
# Get from: https://cloud.mongodb.com → Connect → Connect your application
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/taskflow?retryWrites=true&w=majority

# JWT Secret — use a long random string
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
